# PalantINT Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=palantint
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── Backend ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET

# Comma-separated list of allowed CORS origins (e.g. https://palantint.example.com)
CORS_ORIGINS=http://localhost:80

# MCP Configuration (Internal credentials for tool access)
MCP_SERVICE_TOKEN=internal_mcp_secret_change_me

# ── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
