# PalantINT Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Application Environment ────────────────────────────────────────────────
# Controls development vs production behavior.
# In "development", OpenAPI Swagger UI (/api/docs) is automatically enabled.
ENVIRONMENT=development

# Explicitly enable or disable FastAPI OpenAPI / Swagger UI docs (/api/docs & /api/openapi.json)
ENABLE_DOCS=true

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=palantint
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ── Backend Security ────────────────────────────────────────────────────────
# Secret key used for JWT signing. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_SECRET

# Comma-separated list of allowed CORS origins.
# Note: When running behind Nginx reverse proxy, frontend and backend share the same origin, 
# making CORS checks unnecessary. In standalone dev mode (e.g. Next.js on port 3000), include http://localhost:3000.
CORS_ORIGINS=http://localhost:80,http://localhost:3000

# MCP Configuration (Internal credentials for AI agent tool access)
MCP_SERVICE_TOKEN=internal_mcp_secret_change_me

# ── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
